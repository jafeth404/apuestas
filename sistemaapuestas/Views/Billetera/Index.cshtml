@model BilleteraViewModel

@{
    ViewData["Title"] = "Mi Billetera";
}

<h2><i class="bi bi-wallet2"></i> Mi Billetera</h2>
<hr />

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card bg-success text-white shadow">
            <div class="card-body text-center">
                <h5>Saldo Disponible</h5>
                <h2 class="display-6">@Model.Moneda @Model.Saldo.ToString("F2")</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <a asp-action="Depositar" class="btn btn-primary btn-lg w-100 h-100 d-flex align-items-center justify-content-center">
            <div class="text-center">
                <i class="bi bi-plus-circle fs-1"></i><br />
                Depositar
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-action="Retirar" class="btn btn-warning btn-lg w-100 h-100 d-flex align-items-center justify-content-center">
            <div class="text-center">
                <i class="bi bi-dash-circle fs-1"></i><br />
                Retirar
            </div>
        </a>
    </div>
</div>

<h4><i class="bi bi-arrow-left-right"></i> Historial de Movimientos</h4>

@if (!Model.Movimientos.Any())
{
    <div class="alert alert-info">No hay movimientos registrados.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Fecha</th>
                    <th>Tipo</th>
                    <th>Monto</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var mov in Model.Movimientos)
                {
                    <tr>
                        <td>@mov.Fecha.ToLocalTime().ToString("dd/MM/yy HH:mm")</td>
                        <td>
                            <span class="badge @(mov.Tipo switch { "deposito" => "bg-success", "retiro" => "bg-danger", "apuesta" => "bg-warning text-dark", "ganancia" => "bg-info text-dark", _ => "bg-secondary" })">
                                @mov.Tipo
                            </span>
                        </td>
                        <td class="@(mov.Monto >= 0 ? "text-success" : "text-danger") fw-bold">
                            @(mov.Monto >= 0 ? "+" : "")$@mov.Monto.ToString("F2")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
