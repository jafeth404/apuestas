@model LoginViewModel

@{
    ViewData["Title"] = "Iniciar Sesión";
}

<h2><i class="bi bi-box-arrow-in-right"></i> Iniciar Sesión</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Correo" class="form-label"></label>
                <input asp-for="Correo" class="form-control" type="email" />
                <span asp-validation-for="Correo" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Contrasena" class="form-label"></label>
                <input asp-for="Contrasena" class="form-control" />
                <span asp-validation-for="Contrasena" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">
                <i class="bi bi-box-arrow-in-right"></i> Ingresar
            </button>

            <a asp-action="Registro" class="btn btn-link">¿No tienes cuenta? Regístrate</a>
            <hr />
            <a asp-controller="AdminAuth" asp-action="LoginAdmin" class="btn btn-outline-dark btn-sm">
                <i class="bi bi-shield-lock"></i> Acceso Administradores
            </a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
